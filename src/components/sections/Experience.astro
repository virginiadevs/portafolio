---
import { work } from '@cv'
import Section from "@/components/Section.astro"
---

<Section title="Experiencia">
    <ul>
        {
            work.map(
                ({ name, startDate, endDate, position, summary }) => {
                const startYear = new Date(startDate).getFullYear()
                const endYear = endDate != null ? new Date(endDate).getFullYear() : "Presente"
                const years = `${startYear} - ${endYear}`
                
                return (
                    <li>
                        <article>
                            <header>
                                <h3>{position}</h3>
                                <h4>{name} <time>| {years}</time></h4>
                            </header>

                            <footer>
                                <p>{summary}</p>
                            </footer>
                        </article>                        
                    </li>
                )
            })
        }
    </ul>
</Section>

<style>
    article {
        display: flex;
        flex-direction: column;
        gap: .5rem;
    }

    article h3 {
        font-weight: 600;
        font-size: 1rem;
        margin-bottom: 4px;
    }

    time {
        font-weight: 400;
        color: #666;
        font-size: .85rem;
    }
</style>