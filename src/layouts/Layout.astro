---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/ico" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Tags para la preview -->
		<meta property="og:title" content={title}>
		<meta property="og:image" content="/captura-portafolio.webp">
		<meta property="og:description" content="This is just an example page.">
		<meta property="og:url" content="https://example.com/page.html"> <!-- PONER MI GITHUB PAGES -->
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	:root {
        --brand-color1: #1A8359;
        --brand-color2: #86C337;
        --brand-color3: #c7eec7;
		--brand-color4: #c7eec750;
    }

	html {
		font-family: system-ui, sans-serif;
		background: #fff;
		letter-spacing: -0.025rem;
	}

	code {
		font-family:
			Menlo,
			Monaco,
			Lucida Console,
			Liberation Mono,
			DejaVu Sans Mono,
			Bitstream Vera Sans Mono,
			Courier New,
			monospace;
	}

	body, figure {
		margin: 0;
		padding: 0;
	}

	a {
		text-decoration: none;
	}
	
	ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	*, *::before, *::after {
		box-sizing: border-box;
	}

	h1, h2, h3, h4 {
		margin: 0;
		font-family: 
			system-ui, 
			-apple-system, 
			BlinkMacSystemFont, 
			'Segoe UI', 
			Roboto, 
			Oxygen, 
			Ubuntu, 
			Cantarell, 
			'Open Sans', 
			'Helvetica Neue', 
			sans-serif;
	}

	h2 {
		font-weight: 600 !important;
	}

	h4 {
        font-size: .85rem;
		color: #666;
		font-weight: 400;
        letter-spacing: -0.05rem;
	}

	p {
		color: #333;
		font-size: 0.9rem;
		line-height: 1.5;
		margin: 0;
		text-wrap: pretty;
	}

	body {
		/*background: #faf7f5;
		background: var(--brand-color4);*/

		position: relative;
		z-index: -2;
		height: 100%;
		width: 100%;
		top: 0;
		/*background: radial-gradient(170% 190% at 50% 50%, #fff 22%, var(--brand-color1) 100%);
		background: radial-gradient(60% 80% at 50% 50%, #fff 0, var(--brand-color4) 100%);*/
		background: radial-gradient(ellipse 80% 80% at 50% -20%, #fff, var(--brand-color4));		
	}
</style>
